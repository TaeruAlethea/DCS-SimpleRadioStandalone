<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Ciribob.DCS.SimpleRadio.Standalone.Client.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Ciribob.DCS.SimpleRadio.Standalone.Client.Views"
        x:Class="Ciribob.DCS.SimpleRadio.Standalone.Client.Views.MainWindow"
        mc:Ignorable="d" 
        Icon="/Assets/audio-headset.ico"
        Width="550" Height="710"
        d:DesignWidth="550" d:DesignHeight="710"
        CanResize="False" >
        
        <views:MainView />
</Window>
